# Copier vers .env et adapter les valeurs.

# PostgreSQL (même URL qu’en Docker Compose par défaut)
DATABASE_URL=postgresql+asyncpg://yuki:yuki@localhost:5433/yuki

# Mot de passe de l’application (hash bcrypt). Mot de passe clair par défaut : yuki-dev
YUKI_PASSWORD_HASH=$2b$12$90ubnlfmT.GqhFpGXhYtOevE2hRLMhxIxltKHrdETebqI/dTmVtBK

# JWT — utiliser une valeur longue et aléatoire en production
JWT_SECRET=changez-moi-en-production

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
# Optionnel : llava pour décrire les images sur /upload
OLLAMA_VISION_MODEL=

# CORS (Vite par défaut sur 5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
